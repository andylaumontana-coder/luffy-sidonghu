# LLM provider (NVIDIA API or any OpenAI-compatible endpoint)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# Optional: a smaller / faster model for the facilitator (defaults to NVIDIA_MODEL)
NVIDIA_FAST_MODEL=

# Server
PORT=3001

# Data dir for SQLite (defaults to ./data)
LUFFY_DATA_DIR=

# Rate limits (per IP, sliding 1h window)
LUFFY_LIMIT_CREATE_PER_HOUR=5
LUFFY_LIMIT_LLM_PER_HOUR=60

# LLM call timeouts (ms)
LUFFY_TIMEOUT_FACILITATOR_MS=30000
LUFFY_TIMEOUT_PERSONA_MS=45000
LUFFY_TIMEOUT_SUMMARY_MS=60000
